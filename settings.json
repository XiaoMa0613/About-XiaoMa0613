{
    "editor.fontSize": 16,
    "workbench.colorTheme": "Monokai",
    "C_Cpp.default.compileCommands": [


        ""
    ],
    "C_Cpp.default.compilerPath": "D:\\mingw64_13.1\\bin",
    "terminal.integrated.env.windows": {

    },
    "window.confirmSaveUntitledWorkspace": false,
    // 文件注释的组成及其排序
    "doxdocgen.file.fileOrder": [
        "file",     // @file
        "brief",    // @brief 简介
        "author",   // 作者
        "version",  // 版本
        "date",     // 日期
        "empty",    // 空行
        "copyright",// 版权
        "empty",
        "custom"    // 自定义
    ],
     // 下面时设置上面标签tag的具体信息
    "doxdocgen.generic.authorName": "MaCaiyu",
    "doxdocgen.generic.authorEmail": "macy1@ampacetech.com",
    "doxdocgen.generic.authorTag": "@author{indent:12} {author} ({email})",
    "doxdocgen.file.fileTemplate": "@file{indent:12} {name}",
    "doxdocgen.file.copyrightTag": [
        
        "@copyright{indent:12} 东莞新能安科技有限公司"],
    "doxdocgen.file.customTag": ["*****************************************************************************"],
    "doxdocgen.generic.briefTemplate": "@brief{indent:12} {text}",
    "doxdocgen.generic.dateTemplate": "@date{indent:12} {date}",

    // 根据自动生成的注释模板（目前主要体现在函数注释上）
    //{indent:12}占位符 对其第12列
    "doxdocgen.generic.dateFormat": "YYYY-MM-DD", // 设置日期格式
    "doxdocgen.generic.paramTemplate": "@param{indent:12} {param} ", // 参数模板
    "doxdocgen.generic.returnTemplate": "@return{indent:12} {type} ", // 返回值模板
    "doxdocgen.generic.order": [

        "brief",      // 简介
        "author",     // 作者
        "empty",      // 空行
        "param",      // 参数
        "return",     // 返回值
        "date"        // 日期
    ],
    "doxdocgen.generic.boolReturnsTrueFalse": false,    // bool 返回值拆分成 true 和 false 两种情况
    "doxdocgen.generic.linesToGet": 10,                  // 回车后最多向下多少行去找函数声明
    "doxdocgen.generic.useGitUserName": false,          // {author} 是都根据 git config --get user.name 替换
    "doxdocgen.generic.useGitUserEmail": false,
    "doxdocgen.file.versionTag": "@version{indent:12} 0.1",
    "git.autofetch": true,
    "gitlens.ai.model": "vscode",
    "gitlens.ai.vscode.model": "copilot:gpt-4.1",
    "github.copilot.nextEditSuggestions.enabled": true,
    //declarations or definitions anymore.

}